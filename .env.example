# Copy to `.env` and fill in real values. `.env` is gitignored.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# For mobile QA over an ngrok tunnel, add the tunnel host + origin:
#   DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,abc123.ngrok-free.app
#   CSRF_TRUSTED_ORIGINS=https://abc123.ngrok-free.app
CSRF_TRUSTED_ORIGINS=

# Database (M1 uses SQLite by default; switch to Postgres at M6)
# DATABASE_URL=postgres://user:pass@localhost:5432/laihub

# Celery / Redis (M2+; not used in M1 but settings reads them)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Google OAuth (fill in from Google Cloud Console; M1 can defer)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Email (M1: console backend; production: SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@laihub.local

# LingBot-Map pipeline (M3+)
# LINGBOT_MAP_ROOT: absolute path to the lingbot-map repo root
# LINGBOT_MAP_PYTHON: Python interpreter with torch + lingbot_map installed
#   Windows conda env example: C:/ProgramData/anaconda3/envs/lingbot/python.exe
#   or: C:/Users/<user>/anaconda3/envs/lingbot/python.exe
# LINGBOT_MAP_MODEL_PATH: path to checkpoint (relative to ROOT, or absolute)
LINGBOT_MAP_ROOT=C:/Users/ironm/dev/lingbot-map
LINGBOT_MAP_PYTHON=python
LINGBOT_MAP_MODEL_PATH=checkpoints/lingbot-map-long.pt
