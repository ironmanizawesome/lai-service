# ── Home GPU worker env (M6 split deployment) ────────────────────────────────
# Copy to `.env.worker` and fill in. Loaded via ENV_FILE by run_worker_cloud.ps1.
# `.env.worker` is gitignored — never commit real secrets.
#
# This worker runs the Celery process in the lai-service .venv and shells out to
# LINGBOT_MAP_PYTHON (conda env with torch+CUDA) for precompute_npz.py — so this
# machine is the only place inference actually runs.
#
# The DATABASE_URL / CELERY_BROKER_URL / AWS_* values MUST be identical to the
# ones set on the Render web service — that shared state is how the two halves
# of the deployment talk to each other.

DJANGO_DEBUG=False
# Any long random string; does not need to match the web service.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# ── Shared data tier (SAME values as Render web) ─────────────────────────────
# Neon Postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Upstash Redis (TLS → rediss://)
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST:PORT/0
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST:PORT/1

# Cloudflare R2
AWS_STORAGE_BUCKET_NAME=laihub-media
AWS_ACCESS_KEY_ID=<R2 access key id>
AWS_SECRET_ACCESS_KEY=<R2 secret access key>
AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

# ── Local GPU (worker-only; the web service does NOT set these) ───────────────
LINGBOT_MAP_ROOT=C:/Users/ironm/dev/lingbot-map
LINGBOT_MAP_PYTHON=C:/Users/ironm/anaconda3/envs/lingbot-map/python.exe
LINGBOT_MAP_MODEL_PATH=checkpoints/lingbot-map-long.pt
